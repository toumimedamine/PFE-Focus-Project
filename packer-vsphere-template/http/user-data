#cloud-config
autoinstall:
  version: 1

  identity:
    hostname: ubuntu-template
    username: ubuntu
    password: "$6$REPLACE_WITH_REAL_HASH"

  ssh:
    install-server: true
    allow-pw: true

  locale: en_US
  keyboard:
    layout: us

  storage:
    layout:
      name: direct

  network:
    version: 2
    ethernets:
      ens192:
        dhcp4: false
        addresses:
          - 10.1.10.4/24
        routes:
          - to: default
            via: 10.1.10.254
        nameservers:
          addresses:
            - 10.1.10.2
            - 8.8.8.8

  packages:
    - open-vm-tools
    - openssh-server

  late-commands:
    - curtin in-target --target=/target systemctl enable ssh
    - curtin in-target --target=/target systemctl start ssh
